# =============================================================================
# HRM バックエンド 環境変数テンプレート
# このファイルをコピーして .env を作成してください：
#   cp .env.example .env
#
# CDK デプロイ後に出力される値（Outputs）を以下に設定してください。
# =============================================================================

# --- Django 基本設定 -----------------------------------------------------------
DJANGO_ENV=dev                          # dev / stg / prod
DJANGO_SECRET_KEY=your-secret-key-here  # python -c "import secrets; print(secrets.token_hex(50))" で生成
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_DEBUG=True                       # 本番環境では False に変更

# --- データベース（Amazon RDS PostgreSQL）--------------------------------------
# CDK Output: DbEndpoint の値を設定
DB_HOST=localhost                       # ローカル開発時は localhost
DB_PORT=5432
DB_NAME=hrm
DB_USER=hrm_admin
DB_PASSWORD=your-db-password-here       # ローカル開発用パスワード

# 本番環境では DB_SECRET_ARN を設定（DB_USER/DB_PASSWORDの代わりに使用）
# CDK Output: DbSecretArn の値を設定
DB_SECRET_ARN=

# --- AWS 共通設定 --------------------------------------------------------------
AWS_REGION=ap-northeast-1

# ローカル開発時のみ設定（本番はIAMロールで自動認証）
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Amazon S3 ----------------------------------------------------------------
# CDK Output: StorageBucketName の値を設定
S3_STORAGE_BUCKET=hrm-dev-storage-xxxxxxxxxxxx

# CDK Output: TemplateBucketName の値を設定
S3_TEMPLATE_BUCKET=hrm-dev-templates-xxxxxxxxxxxx

# --- AWS Cognito（ユーザー認証）------------------------------------------------
# CDK Output: UserPoolId の値を設定
COGNITO_USER_POOL_ID=ap-northeast-1_xxxxxxxxx

# CDK Output: UserPoolClientId の値を設定
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Amazon Bedrock（AI機能）--------------------------------------------------
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5-20250929-v1:0

# --- メール送信（Amazon SES）--------------------------------------------------
# 本番環境で設定。開発環境はコンソール出力で代替
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django_ses.SESBackend
# AWS_SES_REGION_NAME=ap-northeast-1

# --- CORS 設定（フロントエンドのURLを設定）------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- その他 -------------------------------------------------------------------
# タイムゾーン
TIME_ZONE=Asia/Tokyo
